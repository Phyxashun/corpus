  //@========================================
  //@     ⚙️ INDENT RAINBOW SETTINGS
  //@========================================
  "indentRainbow.indicatorStyle": "classic",
  "indentRainbow.lightIndicatorStyleLineWidth": 1,
  "indentRainbow.colorOnWhiteSpaceOnly": true,
  "indentRainbow.updateDelay": 100,
  "indentRainbow.ignoreErrorLanguages": [
    "haskell"
  ],
  "indentRainbow.errorColor": "rgba(128,32,32,0.6)",
  "indentRainbow.tabmixColor": "rgba(128,32,96,0.6)",
  "indentRainbow.colors": [
    "rgba(255,255,64,0.07)",
    "rgba(127,255,127,0.07)",
    "rgba(255,127,255,0.07)",
    "rgba(79,236,236,0.07)"
  ],
  //@========================================
  //@     🎨 COLORIZE SETTINGS
  //@========================================
  "colorize.decoration_type": "background", //@"background", "underline", "outline", "dot", "square-dot"
  "colorize.enable_search_variables": true,
  "colorize.hide_current_line_decorations": true,
  "colorize.colorized_colors": [
    "HEXA", //@hexadecimal colors: #RGB, #RGBA, #RRGGBB, #RRGGBBAA, 0xRGB, 0xRGBA, 0xRRGGBB or 0xRRGGBBAA
    "ARGB", //@argb colors: #RGB, #ARGB, #RRGGBB or #AARRGGBB
    "RGB", //@rgb colors: rgb(r,g,b) or rgba(r,g,b,a)
    "HSL", //@HSL colors
    //"BROWSERS_COLORS", //@native browser's colors like white, red, blue...
    "OKLAB", //@oklab colors
    "OKLCH" //@oklch colors
  ],
  "colorize.languages": [
    "css",
    "scss",
    "sass",
    "less",
    "html",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "json",
    "jsonc",
    "toml",
    "python",
    "java",
    "powershell",
    "ps1",
    "psd1",
    "markdown",
    "md",
    "mdx"
  ],
  "colorize.include": [
    "**/src/**",
    "*.html"
  ],
  "colorize.exclude": [
    "**/node_modules/**",
    "**/ALL/**"
  ],
  "colorize.colorized_variables": [
    "LESS"
  ],
  //@========================================
  //@     🎨 HIGHLIGHT SETTINGS
  //@========================================
  //
  // Dracula Classic:
  // Token	        Hex	        Usage
  // -------------------------------------------------------------------------
  // Background	    #282A36	    Main background
  // Current Line	    #6272A4	    Semantic current line highlight token
  // Selection	    #44475A	    Text selection
  // Foreground	    #F8F8F2	    Default text
  // Comment	        #6272A4	    Comments, disabled code
  // Red	            #FF5555	    Errors, warnings, deletion
  // Orange	        #FFB86C	    Numbers, constants, booleans
  // Yellow	        #F1FA8C	    Strings, text content
  // Green	        #50FA7B	    Functions, methods, inherited classes
  // Cyan	            #8BE9FD	    Classes, types, support, regex
  // Purple	        #BD93F9	    Instance reserved words, constants
  // Pink	            #FF79C6	    Keywords, storage types
  //
  //
  "highlight.decorations": {},
  "highlight.regexFlags": "gi",
  "highlight.regexes": {
    //$ Highlight file paths in comments with a specific format, e.g.:
    // FILE-PATH: src/styles.css
    // file-path: test/test
    // #~ file-path: test/test
    //
    //   2         3        4     5
    "([^\\s\\t]?(\/\/|#~)\\s?(FILE-PATH)\\s?(:)\\s?(.*)\\h?)": {
      "regexFlags": "gim",
      "filterLanguageRegex": "markdown|javascript|typescript|js|ts|json|jsonc|ignore",
      "decorations": [
        { // Group 1 - entire match
          "borderRadius": "4px",
          "border": "1px solid #FFB86C",
          "backgroundColor": "#44475A",
          "overviewRulerColor": "#FFB86C"
        },
        { // Group 2 - '//' | '#'
          "color": "#FFB86C"
        },
        { // Group 4 - 'file-path'
          "color": "#FF79C6",
          "fontWeight": "bold"
        },
        { // Group 5 - ':'
          "color": "#FFB86C"
        },
        { // Group 6 - actual path
          "color": "#BD93F9",
          "textDecoration": "none; padding: 0 8px 0 0;",
          "after": {
            "contentText": " "
          }
        }
      ]
    },
    //$ Highlight web URLs in comments with a specific format, e.g.:
    // https://www.example.com
    // http://localhost
    // https://localhost:8080/dashboard#metrics
    // http://127.0.0.1:3000
    // https://cspell.org
    // ftp://files.local/shared/data.csv
    "/[\\s\\t]?(?:https?|ftp):\\/\\/(?:[a-zA-Z0-9:%._\\+~#=\\-]+|\\[[0-9a-fA-F:]+\\])(?::\\d+)?(?:\\/[-a-zA-Z0-9()@:%_\\+.~#?&\\/=]*)*/gi": {
      "decorations": [
        {
          "color": "white",
          "borderRadius": "12px",
          "border": "0.5px dashed #FFB86C",
          "backgroundColor": "#44475A",
          "fontWeight": "100",
          "textDecoration": "none; padding: 0 8px 0 0;",
          "after": {
            "contentText": " "
          }
        }
      ]
    },
    //$ Highlight comments that start with '#'
    "/^[ \\t]*(#(?!~).*)$/gm": {
      "filterLanguageRegex": "ignore|toml|yaml|ini",
      "decorations": [
        {
          "color": "#50fa7b",
          "backgroundColor": "transparent",
          "fontWeight": "bold",
          "textDecoration": "none"
        }
      ]
    },
    "/^[ \\t]*([^#\\s][^#\\n]*\\/(?:\\*\\*\\/\\*|\\*)?)$/gm": {
      "filterLanguageRegex": "ignore",
      "decorations": [
        {
          "color": "#8BE9FD",
          "backgroundColor": "transparent",
          "fontWeight": "100",
          "textDecoration": "none"
        }
      ]
    },
    "/^[ \\t]*([^#\\s!\\n][^#\\n]*?\\.[a-zA-Z0-9*?{}.,_-]+)$/gm": {
      "filterLanguageRegex": "ignore",
      "decorations": [
        {
          "color": "#F1FA8C",
          "backgroundColor": "transparent",
          "fontWeight": "100",
          "textDecoration": "none"
        }
      ]
    }
  },
  //@========================================
  //@     📖 CSPELL DICTIONARY SETTINGS
  //@========================================
  "cSpell.language": "en_US",
  "cSpell.dictionaries": [
    "en_US",
    "typescript",
    "javascript",
    "html",
    "css",
    "markdown",
    "npm",
    "node",
    "react-components",
    "software-terms"
