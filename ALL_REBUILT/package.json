{
  "name": "corpus",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun run typecheck && bun build --compile --outfile=./dist/consolidate ./src/index.ts",
    "start": "bun run ./src/index.ts",
    "test:log": "powershell -ExecutionPolicy Bypass -File ./log-tests.ps1"
  },
  "bin": {
    "corpus": "./src/index.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-plugin": "^7.4.2",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "istanbul": "^0.4.5",
    "jiti": "^2.7.0",
    "prettier": "^3.9.5",
    "prettier-plugin-toml": "^2.0.6",
    "typescript-eslint": "^8.64.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "picocolors": "^1.1.1"
  }
}
